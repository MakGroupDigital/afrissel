# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase public web config for AfriSell.
VITE_FIREBASE_API_KEY="AIzaSyCdqNyHc2Fgr3brSc5oWR1ucEYzi_4rza4"
VITE_FIREBASE_AUTH_DOMAIN="afrisellapp.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="afrisellapp"
VITE_FIREBASE_STORAGE_BUCKET="afrisellapp.firebasestorage.app"
VITE_FIREBASE_DATABASE_URL="https://afrisellapp-default-rtdb.firebaseio.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="582531352090"
VITE_FIREBASE_APP_ID="1:582531352090:web:9d42ce03733cc885f7f3a3"
VITE_FIREBASE_MEASUREMENT_ID="G-X2LJE0WH51"

# Cloudinary signed uploads. Keep secret values server-side only.
CLOUDINARY_CLOUD_NAME="dh0ilegll"
CLOUDINARY_API_KEY="YOUR_CLOUDINARY_API_KEY"
CLOUDINARY_API_SECRET="YOUR_CLOUDINARY_API_SECRET"
